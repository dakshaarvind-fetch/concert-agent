# ── uAgents / Agentverse ──────────────────────────────────────────────────────
AGENT_SEED_PHRASE=                  # stable 12-word phrase — defines agent address
AGENTVERSE_API_KEY=                 # agentverse.ai → Profile → API Keys

# ── LLM + Embeddings ─────────────────────────────────────────────────────────
ASI_API_KEY=                        # ASI:One — chat completions + embeddings
ASI_MODEL=asi1                      # optional override: asi1 | asi1-mini | asi1-extended

# ── Event APIs ────────────────────────────────────────────────────────────────
TICKETMASTER_API_KEY=
EVENTBRITE_API_KEY=                 # optional — indie/smaller venue fallback

# ── Database ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=               # service-role key — never expose client-side

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=concert-concierge
