# ── uAgents / Agentverse ──────────────────────────────────────────────────────
AGENT_SEED_PHRASE=                  # stable 12-word phrase — defines agent address
AGENTVERSE_API_KEY=                 # agentverse.ai → Profile → API Keys

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ASI_API_KEY=                        # optional — ASI:One LLM fallback

# ── Embeddings ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=                     # used for text-embedding-3-small

# ── Event APIs ────────────────────────────────────────────────────────────────
TICKETMASTER_API_KEY=
SONGKICK_API_KEY=

# ── Spotify ───────────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=               # service-role key — never expose client-side

# ── Email ─────────────────────────────────────────────────────────────────────
GMAIL_SMTP_USER=
GMAIL_SMTP_APP_PASSWORD=
# -- OR --
RESEND_API_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=concert-concierge
